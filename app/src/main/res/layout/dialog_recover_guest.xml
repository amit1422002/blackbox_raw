<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/white"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:id="@+id/recover_dialog_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/recover_guest_bgmi_title"
        android:textColor="@color/recover_accent"
        android:textSize="18sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/recover_dialog_hint"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="@string/recover_guest_bgmi_hint"
        android:textColor="@color/secondary_text"
        android:textSize="12sp" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recover_guest_list"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:clipToPadding="false"
        android:maxHeight="280dp"
        android:overScrollMode="never"
        android:scrollbars="vertical" />

    <LinearLayout
        android:id="@+id/recover_selected_panel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:background="@drawable/bg_recover_guest_selected"
        android:orientation="vertical"
        android:padding="10dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/recover_guest_bgmi_selected_label"
            android:textColor="@color/recover_accent"
            android:textSize="11sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/recover_selected_summary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="@color/primary_text"
            android:textSize="13sp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:gravity="end"
        android:orientation="horizontal">

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/recover_btn_cancel"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:background="@drawable/bg_recover_guest_normal"
            android:minWidth="88dp"
            android:text="@android:string/cancel"
            android:textAllCaps="false"
            android:textColor="@color/primary_text"
            android:textSize="13sp" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/recover_btn_restore"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:layout_marginStart="10dp"
            android:background="@drawable/bg_recover_guest_btn_primary"
            android:enabled="false"
            android:minWidth="100dp"
            android:text="@string/recover_guest_bgmi_restore"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textSize="13sp" />
    </LinearLayout>
</LinearLayout>
